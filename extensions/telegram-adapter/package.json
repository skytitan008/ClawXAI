{
  "name": "@clawxai/telegram-adapter",
  "version": "1.2.0",
  "private": true,
  "description": "Telegram channel adapter for ClawXAI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clawxai/core": "workspace:*",
    "telegraf": "^4.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0"
  }
}
