{
  "id": "@clawxai/pai-memory-enhanced",
  "version": "1.0.0",
  "displayName": "PAI Enhanced Memory",
  "description": "Long-term memory, knowledge graph, and learning engine",
  "author": "ClawXAI Team",
  "license": "MIT",
  "type": "extension",
  "main": "index.ts",
  "categories": ["Memory", "Learning", "Knowledge"],
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": { "type": "boolean", "default": true },
      "autoConsolidate": { "type": "boolean", "default": true },
      "maxMemories": { "type": "number", "default": 1000 }
    }
  },
  "capabilities": { "dashboard": true, "api": true },
  "dashboard": {
    "pages": [
      {
        "path": "/memory",
        "title": "Memory Dashboard",
        "icon": "brain",
        "file": "./assets/memory-dashboard.html"
      }
    ]
  },
  "api": {
    "endpoints": [
      { "path": "/memory/store", "methods": ["POST"] },
      { "path": "/memory/retrieve", "methods": ["GET"] },
      { "path": "/memory/stats", "methods": ["GET"] }
    ]
  }
}
