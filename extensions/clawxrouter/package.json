{
  "name": "ClawXRouter",
  "version": "1.0.6",
  "description": "Edge-cloud collaborative routing plugin that keeps sensitive data local and routes tasks to cost-effective models — protects user privacy by classifying requests into three safety levels and redacting PII before any cloud forwarding",
  "keywords": [
    "clawxrouter",
    "guard-agent",
    "openclaw",
    "privacy",
    "router"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenBMB/ClawXRouter"
  },
  "files": [
    "index.ts",
    "src/",
    "prompts/",
    "config.example.json",
    "openclaw.plugin.json"
  ],
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48",
    "synckit": "^0.11.12",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.22"
    },
    "build": {
      "openclawVersion": "2026.3.28"
    }
  }
}
