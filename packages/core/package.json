{
  "name": "@clawxai/core",
  "version": "0.1.0",
  "private": true,
  "description": "ClawXAI core engine based on OpenClaw",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./gateway": {
      "import": "./dist/gateway.js",
      "types": "./dist/gateway.d.ts"
    },
    "./agents": {
      "import": "./dist/agents.js",
      "types": "./dist/agents.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@clawxai/router": "workspace:*",
    "@clawxai/memory": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
