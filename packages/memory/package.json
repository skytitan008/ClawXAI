    "clean": "rm -rf dist/"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  }
}
