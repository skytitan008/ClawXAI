{
  "name": "@clawxai/memory",
  "version": "0.1.0",
  "private": true,
  "description": "ClawXAI memory - L0/L1/L2 layered memory system (from EdgeClaw)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
